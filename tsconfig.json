{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"strict": true,
		"paths": {
			"@/*": ["./*"],
			"@/UI/*": ["./src/UI/*"],
			"@/hooks/*": ["./src/hooks/*"],
			"@/svg/*": ["./assets/svg/*"],
			"@/images/*": ["./assets/images/*"],
			"@/translations/*": ["./src/translations/*"],
			"@/types/*": ["./src/types/*"]
		}
	},
	"include": [
		"**/*.ts",
		"**/*.tsx",
		".expo/types/**/*.ts",
		"expo-env.d.ts",
		"nativewind-env.d.ts",
		"babel.config.js"
	]
}
